# Keep shell scripts LF so they run on macOS/Linux even when authored on Windows
*.sh   text eol=lf

# Keep PowerShell scripts CRLF for Windows
*.ps1  text eol=crlf

# Docker files use LF (Linux build context)
Dockerfile     text eol=lf
.dockerignore  text eol=lf

# Node.js entry point uses LF (cross-platform)
*.js   text eol=lf

# Normalize the rest
*.md   text
*.html text
*.yaml text
*.yml  text
