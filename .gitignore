# LiteLLM virtual environment (created by setup-litellm.ps1)
.venv/
litellm-env/

# NOTE: config/litellm_config.yaml IS committed (a working example). It is
# regenerated on every run, so it may show as modified when you change model/provider.

# Proxy log written by start-claude.sh
litellm-proxy.log
*.log

# Secrets / local env files
.env
.env.*
*.key

# OS / editor cruft
Thumbs.db
desktop.ini
.vscode/

# Claude Code local-only settings
.claude/settings.local.json
